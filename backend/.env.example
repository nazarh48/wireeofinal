# ================================
# Server Configuration
# ================================
PORT=5000

# ================================
# MongoDB Configuration
# ================================
# For local development:
MONGODB_URI=mongodb://localhost:27017/wireeo

# For production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://wireeo:wireeo%401106@cluster0.bxv3xwx.mongodb.net/wireeodb?retryWrites=true&w=majority

# ================================
# JWT Configuration
# ================================
# IMPORTANT: Use a strong, unique secret in production
JWT_SECRET=wireeo@1106secret
JWT_EXPIRES_IN=7d

# ================================
# CORS Configuration
# ================================
# Comma-separated list of allowed origins
# For development:
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# For production (recommended - specify your domain):
# CORS_ORIGIN=https://wireeo.com

# To allow all origins (use only for testing):
# CORS_ORIGIN=*

# ================================
# App / Frontend
# ================================
# Frontend base URL (for email verification and other email links)
# Development:
FRONTEND_URL=http://localhost:5173
# Production (set on server so verification emails use https://wireeo.com):
# FRONTEND_URL=https://wireeo.com

# ================================
# Email (SMTP) Configuration
# ================================
# REQUIRED for real delivery. Without this, emails go to Ethereal test inbox only.
# Copy these to .env and replace with real values.
#
# Gmail:
#   1. Enable 2-Step Verification (Google Account > Security)
#   2. Create App Password: Security > 2-Step Verification > App passwords
#   3. Use your Gmail address and the 16-char app password below
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=xxxx xxxx xxxx xxxx
MAIL_FROM=your-gmail@gmail.com
