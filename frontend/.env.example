# ================================
# API Configuration
# ================================
# Local development:
# Keep browser requests on /api and let Vite proxy them to the backend.
# Change this only if your local backend runs on a different origin/port.
VITE_PROXY_TARGET=http://localhost:5000

# Optional direct API base URL (recommended for production/staging only):
# VITE_API_URL=https://wireeo.com/api

# ================================
# Notes
# ================================
# - In local development, frontend requests use /api and Vite forwards them to VITE_PROXY_TARGET
# - VITE_API_URL is optional and mainly useful for deployed environments
# - Image URLs are automatically constructed from the active API base
# - In production, images are served at: https://wireeo.com/api/uploads/products/
# - In development, images are served through the Vite proxy at: /api/uploads/products/
# - The frontend automatically adapts image paths for each environment
