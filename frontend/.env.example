# ================================
# API Configuration
# ================================
# Base URL for API requests
# 
# For local development (auto-detected by Vite):
VITE_API_URL=http://localhost:5000/api

# For production deployment:
# VITE_API_URL=https://wireeo.com/api

# ================================
# Notes
# ================================
# - Image URLs are automatically constructed based on VITE_API_URL
# - In production, images are served at: https://wireeo.com/api/uploads/products/
# - In development, images are served at: http://localhost:5000/uploads/products/
# - The frontend automatically adapts image paths for each environment
